@model SafeCasino.Models.Game
@{
    ViewData["Title"] = "Game Details";
    var lang = Context.Request.Cookies["language"] ?? "nl";
}

<div class="container py-5">
    <div class="mb-4">
        <a href="/Game" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>@localizationService.GetString("BackToGames", lang)
        </a>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="game-image-card">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" />
                }
                else
                {
                    <div class="placeholder-image text-center">
                        <i class="fas fa-gamepad fa-10x text-muted"></i>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="game-info-card">
                <h1 class="mb-3">@Model.Name</h1>

                <div class="mb-3">
                    <span class="badge bg-primary me-2">@Model.Category</span>
                    @if (Model.IsPopular)
                    {
                        <span class="badge bg-warning">@localizationService.GetString("Popular", lang)</span>
                    }
                    @if (Model.IsNew)
                    {
                        <span class="badge bg-success">@localizationService.GetString("New", lang)</span>
                    }
                </div>

                <p class="lead">@Model.Description</p>

                <div class="game-stats mb-4">
                    <div class="row">
                        <div class="col-6 mb-2">
                            <strong>@localizationService.GetString("MinBet", lang):</strong> €@Model.MinBet
                        </div>
                        <div class="col-6 mb-2">
                            <strong>@localizationService.GetString("MaxBet", lang):</strong> €@Model.MaxBet
                        </div>
                        <div class="col-6 mb-2">
                            <strong>@localizationService.GetString("Players", lang):</strong> @Model.PlayersCount
                        </div>
                        <div class="col-6 mb-2">
                            <strong>@localizationService.GetString("Rating", lang):</strong> @Model.Rating / 5
                        </div>
                    </div>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Game/Play/@Model.Id" class="btn btn-primary btn-lg w-100 mb-2">
                        <i class="fas fa-play me-2"></i>@localizationService.GetString("PlayNow", lang)
                    </a>
                    <button class="btn btn-outline-secondary w-100">
                        <i class="fas fa-heart me-2"></i>@localizationService.GetString("AddToFavorites", lang)
                    </button>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-sign-in-alt me-2"></i>@localizationService.GetString("LoginToPlay", lang)
                    </a>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Rules))
    {
        <div class="row mt-5">
            <div class="col-12">
                <div class="rules-card">
                    <h2 class="mb-4">@localizationService.GetString("HowToPlay", lang)</h2>
                    <div>@Html.Raw(Model.Rules)</div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .game-image-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .placeholder-image {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        padding: 100px 50px;
    }

    .game-info-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .rules-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
</style>