@model SafeCasino.ViewModels.GameDetailViewModel
@{
    ViewData["Title"] = Model.Game.Name;
}

<div class="container py-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Games" asp-action="Index">Spellen</a></li>
            <li class="breadcrumb-item active">@Model.Game.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Game Image & Info -->
        <div class="col-lg-6">
            <div class="card" style="background: var(--bg-card); border: none;">
                <img src="@Model.Game.ThumbnailUrl" alt="@Model.Game.Name" class="card-img-top" style="border-radius: 12px;">
                <div class="card-body">
                    <h2 class="card-title mb-3" style="color: var(--text-light);">@Model.Game.Name</h2>
                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        @if (Model.Game.IsPopular)
                        {
                            <span class="badge badge-popular">
                                <i class="fas fa-fire"></i> POPULAIR
                            </span>
                        }
                        @if (Model.Game.IsNew)
                        {
                            <span class="badge badge-new">
                                <i class="fas fa-star"></i> NIEUW
                            </span>
                        }
                        @if (Model.Game.HasJackpot)
                        {
                            <span class="badge badge-jackpot">
                                <i class="fas fa-trophy"></i> JACKPOT
                            </span>
                        }
                        <span class="badge" style="background: var(--bg-dark);">
                            @Model.Game.Category
                        </span>
                    </div>

                    <p class="card-text" style="color: var(--text-light); margin-bottom: 1.5rem;">@Model.Game.Description</p>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="p-3" style="background: var(--bg-dark); border-radius: 8px;">
                                <small style="color: var(--text-light); display: block; margin-bottom: 0.5rem;">
                                    <i class="fas fa-building"></i> Provider
                                </small>
                                <strong style="color: var(--text-light);">@Model.Game.Provider</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3" style="background: var(--bg-dark); border-radius: 8px;">
                                <small style="color: var(--text-light); display: block; margin-bottom: 0.5rem;">
                                    <i class="fas fa-chart-line"></i> RTP
                                </small>
                                <strong style="color: var(--accent-color);">@Model.Game.RTP.ToString("F2")%</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3" style="background: var(--bg-dark); border-radius: 8px;">
                                <small style="color: var(--text-light); display: block; margin-bottom: 0.5rem;">
                                    <i class="fas fa-coins"></i> Min Inzet
                                </small>
                                <strong style="color: var(--text-light);">€@Model.Game.MinBet</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3" style="background: var(--bg-dark); border-radius: 8px;">
                                <small style="color: var(--text-light); display: block; margin-bottom: 0.5rem;">
                                    <i class="fas fa-coins"></i> Max Inzet
                                </small>
                                <strong style="color: var(--text-light);">€@Model.Game.MaxBet</strong>
                            </div>
                        </div>
                    </div>

                    @if (Model.Game.Tags.Any())
                    {
                        <div class="mb-4">
                            <small style="color: var(--text-light); display: block; margin-bottom: 0.5rem;">
                                <i class="fas fa-tags"></i> Tags
                            </small>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var tag in Model.Game.Tags)
                                {
                                    <span class="badge" style="background: var(--bg-dark); color: var(--text-light);">@tag</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Play", "Games", new { id = Model.Game.Id })" class="btn btn-primary btn-lg">
                            <i class="fas fa-play"></i> Speel Demo
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Game Features & Related -->
        <div class="col-lg-6">
            <!-- Game Features -->
            <div class="card mb-4" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <h4 class="card-title mb-4" style="color: var(--text-light);">
                        <i class="fas fa-info-circle"></i> Over Dit Spel
                    </h4>
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="d-flex align-items-center p-3" style="background: var(--bg-dark); border-radius: 8px;">
                                <i class="fas fa-dice fa-2x me-3" style="color: var(--primary-color);"></i>
                                <div>
                                    <strong style="color: var(--text-light);">Speltype</strong>
                                    <p class="mb-0" style="color: var(--text-light); font-size: 0.9rem;">@Model.Game.Category spel met unieke features</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center p-3" style="background: var(--bg-dark); border-radius: 8px;">
                                <i class="fas fa-mobile-alt fa-2x me-3" style="color: var(--primary-color);"></i>
                                <div>
                                    <strong style="color: var(--text-light);">Mobiel Vriendelijk</strong>
                                    <p class="mb-0" style="color: var(--text-light); font-size: 0.9rem;">Speel op desktop, tablet en mobiel</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center p-3" style="background: var(--bg-dark); border-radius: 8px;">
                                <i class="fas fa-shield-alt fa-2x me-3" style="color: var(--primary-color);"></i>
                                <div>
                                    <strong style="color: var(--text-light);">Eerlijk & Veilig</strong>
                                    <p class="mb-0" style="color: var(--text-light); font-size: 0.9rem;">Gecertificeerde Random Number Generator</p>
                                </div>
                            </div>
                        </div>
                        @if (Model.Game.HasJackpot)
                        {
                            <div class="col-12">
                                <div class="d-flex align-items-center p-3" style="background: linear-gradient(135deg, var(--accent-color) 0%, #ff6b6b 100%); border-radius: 8px;">
                                    <i class="fas fa-trophy fa-2x me-3" style="color: white;"></i>
                                    <div>
                                        <strong style="color: white;">Progressive Jackpot</strong>
                                        <p class="mb-0" style="color: white; font-size: 0.9rem;">Win de grote jackpot!</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Related Games -->
            @if (Model.RelatedGames.Any())
            {
                <div class="card" style="background: var(--bg-card); border: none;">
                    <div class="card-body">
                        <h4 class="card-title mb-4" style="color: var(--text-light);">
                            <i class="fas fa-gamepad"></i> Vergelijkbare Spellen
                        </h4>
                        <div class="row g-3">
                            @foreach (var game in Model.RelatedGames)
                            {
                                <div class="col-12">
                                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id"
                                       class="text-decoration-none">
                                        <div class="d-flex align-items-center p-2"
                                             style="background: var(--bg-dark); border-radius: 8px; transition: all 0.3s ease;"
                                             onmouseover="this.style.background='var(--primary-color)'"
                                             onmouseout="this.style.background='var(--bg-dark)'">
                                            <img src="@game.ThumbnailUrl"
                                                 alt="@game.Name"
                                                 style="width: 80px; height: 60px; object-fit: cover; border-radius: 6px;"
                                                 class="me-3">
                                            <div class="flex-grow-1">
                                                <strong class="d-block" style="color: var(--text-light);">@game.Name</strong>
                                                <small style="color: var(--text-light);">@game.Provider</small>
                                            </div>
                                            <i class="fas fa-chevron-right" style="color: var(--text-light);"></i>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                        <div class="text-center mt-3">
                            <a asp-controller="Games" asp-action="Index" asp-route-category="@Model.Game.Category"
                               class="btn btn-secondary">
                                <i class="fas fa-th"></i> Bekijk Alle @Model.Game.Category Spellen
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Game Rules/Instructions -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <h4 class="card-title mb-4" style="color: var(--text-light);">
                        <i class="fas fa-book"></i> Spelregels & Tips
                    </h4>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <h5 style="color: var(--text-light);"><i class="fas fa-play-circle" style="color: var(--primary-color);"></i> Hoe te Spelen</h5>
                            <p style="color: var(--text-light);">
                                @Model.Game.Name is makkelijk te leren. Selecteer je inzet, start het spel en geniet
                                van de spanning!
                            </p>
                        </div>
                        <div class="col-md-4">
                            <h5 style="color: var(--text-light);"><i class="fas fa-lightbulb" style="color: var(--accent-color);"></i> Tips</h5>
                            <p style="color: var(--text-light);">
                                Begin met de demo modus om het spel te leren kennen. Stel altijd je limieten in voordat
                                je begint met spelen.
                            </p>
                        </div>
                        <div class="col-md-4">
                            <h5 style="color: var(--text-light);"><i class="fas fa-trophy" style="color: var(--success-color);"></i> Winnen</h5>
                            <p style="color: var(--text-light);">
                                Met een RTP van @Model.Game.RTP.ToString("F1")% biedt dit spel eerlijke winkansen.
                                Speel verantwoord en veel succes!
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Back to Games -->
    <div class="text-center mt-4">
        <a asp-controller="Games" asp-action="Index" class="btn btn-secondary btn-lg">
            <i class="fas fa-arrow-left"></i> Terug naar Alle Spellen
        </a>
    </div>
</div>
