@model SafeCasino.ViewModels.GameDetailViewModel
@{
    ViewData["Title"] = "Game Details";
}

<div class="container py-5">
    <div class="mb-4">
        <a href="/Games" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>@Html.Localize("BackToGames")
        </a>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="game-image-card">
                @if (!string.IsNullOrEmpty(Model.Game.ThumbnailUrl))
                {
                    <img src="@Model.Game.ThumbnailUrl" alt="@Model.Game.Name" class="img-fluid rounded" />
                }
                else
                {
                    <div class="placeholder-image text-center">
                        <i class="fas fa-gamepad fa-10x text-muted"></i>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="game-info-card">
                <h1 class="mb-3">@Model.Game.Name</h1>

                <div class="mb-3">
                    <span class="badge bg-primary me-2">@Model.Game.Category</span>
                    @if (Model.Game.IsPopular)
                    {
                        <span class="badge bg-warning">@Html.Localize("Popular")</span>
                    }
                    @if (Model.Game.IsNew)
                    {
                        <span class="badge bg-success">@Html.Localize("New")</span>
                    }
                </div>

                <p class="lead">@Model.Game.Description</p>

                <div class="game-stats mb-4">
                    <div class="row">
                        <div class="col-6 mb-2">
                            <strong>@Html.Localize("MinBet"):</strong> €@Model.Game.MinBet
                        </div>
                        <div class="col-6 mb-2">
                            <strong>@Html.Localize("MaxBet"):</strong> €@Model.Game.MaxBet
                        </div>
                        <div class="col-6 mb-2">
                            <strong>@Html.Localize("Players"):</strong> N/A
                        </div>
                        <div class="col-6 mb-2">
                            <strong>@Html.Localize("Rating"):</strong> N/A
                        </div>
                    </div>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Games/Play/@Model.Game.Id" class="btn btn-primary btn-lg w-100 mb-2">
                        <i class="fas fa-play me-2"></i>@Html.Localize("PlayNow")
                    </a>
                    <button class="btn btn-outline-secondary w-100">
                        <i class="fas fa-heart me-2"></i>@Html.Localize("AddToFavorites")
                    </button>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-sign-in-alt me-2"></i>@Html.Localize("LoginToPlay")
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .game-image-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .placeholder-image {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        padding: 100px 50px;
    }

    .game-info-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
</style>
