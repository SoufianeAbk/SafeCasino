@model SafeCasino.ViewModels.GameListViewModel
@{
    ViewData["Title"] = "Spellen";
}

<div class="container py-5">
    <!-- Games Header -->
    <div class="mb-5">
        <h1 class="section-title mb-3">
            <i class="fas fa-gamepad"></i> Casino Spellen
        </h1>
        <p style="color: var(--text-light);">Ontdek meer dan 50 spannende spellen</p>
    </div>

    <div class="row g-4">
        <!-- Filters Sidebar -->
        <div class="col-lg-3">
            <form method="get" class="filter-section filter-form">
                <!-- Hidden inputs to preserve filter state -->
                <input type="hidden" name="pageSize" value="@Model.Filters.PageSize" />
                <input type="hidden" name="sortBy" value="@Model.Filters.SortBy" />
                <input type="hidden" name="sortDescending" value="@Model.Filters.SortDescending" />
                <input type="hidden" name="pageNumber" value="1" />

                <!-- Preserve all filter selections -->
                <input type="hidden" name="searchTerm" value="@Model.Filters.SearchTerm" />
                <input type="hidden" name="provider" value="@Model.Filters.Provider" />
                <input type="hidden" name="minBet" value="@Model.Filters.MinBet" />
                <input type="hidden" name="maxBet" value="@Model.Filters.MaxBet" />
                <input type="hidden" name="hasJackpot" value="@(Model.Filters.HasJackpot.HasValue? Model.Filters.HasJackpot.Value.ToString().ToLower() : "")" />
                <input type="hidden" name="isNew" value="@(Model.Filters.IsNew.HasValue? Model.Filters.IsNew.Value.ToString().ToLower() : "")" />
                <input type="hidden" name="isPopular" value="@(Model.Filters.IsPopular.HasValue? Model.Filters.IsPopular.Value.ToString().ToLower() : "")" />

                <!-- Search -->
                <div class="mb-3">
                    <label for="SearchTerm" class="form-label" style="color: var(--text-light);"><i class="fas fa-search"></i> Zoeken</label>
                    <input type="text" class="form-control" id="SearchTerm" name="SearchTerm"
                           placeholder="Zoek spellen..." value="@Model.Filters.SearchTerm">
                </div>

                <!-- Category -->
                <div class="mb-3">
                    <label for="Category" class="form-label" style="color: var(--text-light);"><i class="fas fa-th-large"></i> Categorie</label>
                    <select class="form-select" id="Category" name="Category">
                        <option value="">Alle Categorieën</option>
                        @if (Model.AvailableCategories.Any())
                        {
                            @foreach (var category in Model.AvailableCategories)
                            {
                                var _catSelected = Model.Filters.Category == category ? " selected" : string.Empty;
                                @Html.Raw($"<option value=\"{category}\"{_catSelected}>{category}</option>")
                            }
                        }
                    </select>
                </div>

                <!-- Provider -->
                <div class="mb-3">
                    <label for="Provider" class="form-label" style="color: var(--text-light);"><i class="fas fa-building"></i> Provider</label>
                    <select class="form-select" id="Provider" name="Provider">
                        <option value="">Alle Providers</option>
                        @if (Model.AvailableProviders.Any())
                        {
                            @foreach (var provider in Model.AvailableProviders)
                            {
                                var _provSelected = Model.Filters.Provider == provider ? " selected" : string.Empty;
                                @Html.Raw($"<option value=\"{provider}\"{_provSelected}>{provider}</option>")
                            }
                        }
                    </select>
                </div>

                <!-- Bet Range -->
                <div class="mb-3">
                    <label class="form-label" style="color: var(--text-light);"><i class="fas fa-coins"></i> Inzet Bereik</label>
                    <div class="row g-2">
                        <div class="col-6">
                            <input type="number" class="form-control" name="MinBet"
                                   placeholder="Min" value="@Model.Filters.MinBet" step="0.01">
                        </div>
                        <div class="col-6">
                            <input type="number" class="form-control" name="MaxBet"
                                   placeholder="Max" value="@Model.Filters.MaxBet" step="0.01">
                        </div>
                    </div>
                </div>

                <!-- Special Features -->
                <div class="mb-3">
                    <label class="form-label" style="color: var(--text-light);"><i class="fas fa-star"></i> Bijzonderheden</label>

                    <div class="form-check">
                        @Html.CheckBox("HasJackpot", Model.Filters.HasJackpot == true, new { @class = "form-check-input", id = "HasJackpot", value = "true" })
                        <label class="form-check-label" for="HasJackpot" style="color: var(--text-light);">
                            Heeft Jackpot
                        </label>
                    </div>

                    <div class="form-check">
                        @Html.CheckBox("IsNew", Model.Filters.IsNew == true, new { @class = "form-check-input", id = "IsNew", value = "true" })
                        <label class="form-check-label" for="IsNew" style="color: var(--text-light);">
                            Alleen Nieuw
                        </label>
                    </div>

                    <div class="form-check">
                        @Html.CheckBox("IsPopular", Model.Filters.IsPopular == true, new { @class = "form-check-input", id = "IsPopular", value = "true" })
                        <label class="form-check-label" for="IsPopular" style="color: var(--text-light);">
                            Alleen Populair
                        </label>
                    </div>
                </div>

                <!-- Sort -->
                <div class="mb-3">
                    <label for="SortBy" class="form-label" style="color: var(--text-light);"><i class="fas fa-sort"></i> Sorteren</label>
                    <select class="form-select" id="SortBy" name="SortBy">
                        @{
                            var _sName = Model.Filters.SortBy == "Name" ? " selected" : string.Empty;
                            var _sRtp = Model.Filters.SortBy == "RTP" ? " selected" : string.Empty;
                            var _sPop = Model.Filters.SortBy == "Popular" ? " selected" : string.Empty;
                            var _sNew = Model.Filters.SortBy == "New" ? " selected" : string.Empty;
                        }
                        @Html.Raw($"<option value=\"Name\"{_sName}>Naam A-Z</option>")
                        @Html.Raw($"<option value=\"RTP\"{_sRtp}>RTP Hoog naar Laag</option>")
                        @Html.Raw($"<option value=\"Popular\"{_sPop}>Populair</option>")
                        @Html.Raw($"<option value=\"New\"{_sNew}>Nieuwste</option>")
                    </select>
                </div>

                <!-- Buttons -->
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-filter"></i> Filter Toepassen
                    </button>
                    <a href="@Url.Action("Index", "Games")" class="btn btn-secondary clear-filters">
                        <i class="fas fa-times"></i> Filters Wissen
                    </a>
                </div>
            </form>
        </div>

        <!-- Games Grid -->
        <div class="col-lg-9">
            <!-- Results Info -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <p style="color: var(--text-light); margin-bottom: 0;">
                        <strong>@Model.TotalGames</strong> spellen gevonden
                        @if (!string.IsNullOrEmpty(Model.Filters.SearchTerm))
                        {
                            <span>voor "<strong>@Model.Filters.SearchTerm</strong>"</span>
                        }
                    </p>
                </div>
            </div>

            @if (Model.Games.Any())
            {
                <!-- Games Grid -->
                <div class="games-grid">
                    @foreach (var game in Model.Games)
                    {
                        <div class="game-card fade-in">
                            <img src="@game.ThumbnailUrl" alt="@game.Name" class="game-image" />
                            <div class="game-info">
                                <h5 class="game-title">@game.Name</h5>
                                <p class="game-provider">@game.Provider</p>

                                <div class="game-badges mb-2">
                                    @if (game.IsPopular)
                                    {
                                        <span class="badge badge-popular">
                                            <i class="fas fa-fire"></i> POPULAIR
                                        </span>
                                    }
                                    @if (game.IsNew)
                                    {
                                        <span class="badge badge-new">
                                            <i class="fas fa-star"></i> NIEUW
                                        </span>
                                    }
                                    @if (game.HasJackpot)
                                    {
                                        <span class="badge badge-jackpot">
                                            <i class="fas fa-trophy"></i> JACKPOT
                                        </span>
                                    }
                                </div>

                                <div class="mb-2 small">
                                    <div class="d-flex justify-content-between" style="color: var(--text-light);">
                                        <span><i class="fas fa-chart-line"></i> RTP: @game.RTP.ToString("F1")%</span>
                                    </div>
                                    <div class="d-flex justify-content-between" style="color: var(--text-light);">
                                        <span>€@game.MinBet - €@game.MaxBet</span>
                                    </div>
                                </div>

                                <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id"
                                   class="game-play-btn text-decoration-none">
                                    <i class="fas fa-play"></i> Meer Info
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Page navigation" class="mt-5">
                        <ul class="pagination justify-content-center">
                            @if (Model.HasPreviousPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage - 1)">
                                        <i class="fas fa-chevron-left"></i> Vorige
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="fas fa-chevron-left"></i> Vorige</span>
                                </li>
                            }

                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                @if (i == Model.CurrentPage)
                                {
                                    <li class="page-item active">
                                        <span class="page-link">@i</span>
                                    </li>
                                }
                                else if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-route-pageNumber="@i">@i</a>
                                    </li>
                                }
                                else if (i == 2 || i == Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                            }

                            @if (Model.HasNextPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage + 1)">
                                        Volgende <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">Volgende <i class="fas fa-chevron-right"></i></span>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <!-- No Games Found -->
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-3x" style="color: var(--text-gray); margin-bottom: 1rem; display: block;"></i>
                    <h4 style="color: var(--text-light);">Geen spellen gevonden</h4>
                    <p style="color: var(--text-light); margin-bottom: 1rem;">Probeer een ander zoekterm of filter</p>
                    <a asp-action="Index" class="btn btn-primary">
                        <i class="fas fa-redo"></i> Filters Wissen
                    </a>
                </div>
            }
        </div>
    </div>
</div>
