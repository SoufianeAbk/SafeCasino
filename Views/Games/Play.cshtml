@model SafeCasino.ViewModels.GameDetailViewModel
@{
    ViewData["Title"] = "Speel " + Model.Game.Name;
}

<div class="game-play-container">
    <div class="container-fluid">
        <!-- Game Header -->
        <div class="game-header mb-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h1 class="game-title mb-2">@Model.Game.Name</h1>
                    <div class="game-info-bar">
                        <span class="info-item">
                            <i class="fas fa-building"></i> @Model.Game.Provider
                        </span>
                        <span class="separator">|</span>
                        <span class="info-item">
                            <i class="fas fa-chart-line"></i> RTP: @Model.Game.RTP.ToString("F1")%
                        </span>
                        <span class="separator">|</span>
                        <span class="info-item">
                            <i class="fas fa-coins"></i> €@Model.Game.MinBet - €@Model.Game.MaxBet
                        </span>
                        <span class="separator">|</span>
                        <span class="info-item">
                            <i class="fas fa-wallet"></i> Balans: <span class="balance-amount">€1.234,56</span>
                        </span>
                    </div>
                </div>
                <a href="@Url.Action("Details", "Games", new { id = Model.Game.Id })" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Terug naar Details
                </a>
            </div>
        </div>

        <!-- Main Game Container -->
        <div class="game-main-container">
            <!-- Game Viewport -->
            <div class="game-viewport">
                <div id="game-container">
                    <!-- Game will be rendered here -->
                    <div class="text-center">
                        <p style="color: var(--text-light); font-size: 1.1rem; margin-bottom: 1rem;">
                            <i class="fas fa-gamepad fa-3x mb-3" style="display: block; color: var(--primary-color);"></i>
                            Klik op Start Spel om te spelen
                        </p>
                    </div>
                </div>
            </div>

            <!-- Game Controls Panel -->
            <div class="game-controls-panel">
                <!-- Bet Amount -->
                <div class="control-section">
                    <label class="control-label">
                        <i class="fas fa-coins"></i> Inzet
                    </label>
                    <div class="bet-input-group">
                        <input type="number" id="betAmount" value="1.00" min="@Model.Game.MinBet" max="@Model.Game.MaxBet" step="0.01" placeholder="Inzet bedrag">
                    </div>
                    <div class="bet-preset-buttons">
                        <button class="bet-preset-btn" onclick="setBet(0.10)">€0,10</button>
                        <button class="bet-preset-btn" onclick="setBet(1.00)">€1,00</button>
                        <button class="bet-preset-btn" onclick="setBet(5.00)">€5,00</button>
                        <button class="bet-preset-btn" onclick="setBet(10.00)">€10,00</button>
                    </div>
                </div>

                <!-- Stats Display -->
                <div class="control-section">
                    <div class="stat-display">
                        <div class="stat-label">Totale Inzet</div>
                        <div class="stat-value">€<span id="totalBet">1.00</span></div>
                    </div>
                    <div class="stat-display">
                        <div class="stat-label">Huidge Winst</div>
                        <div class="stat-value" style="color: var(--success-color);">€<span id="totalWin">0.00</span></div>
                    </div>
                    <div class="stat-display">
                        <div class="stat-label">Balans</div>
                        <div class="stat-value">€<span id="balance">1234.56</span></div>
                    </div>
                </div>

                <!-- Play Button -->
                <div class="control-section">
                    <button class="btn-play" id="playBtn" onclick="playGame()">
                        <i class="fas fa-play"></i> Start Spel
                    </button>
                </div>

                <!-- Demo Notice -->
                <div class="demo-notice">
                    <i class="fas fa-info-circle"></i> Dit is DEMO modus met virtueel geld
                </div>
            </div>
        </div>

        <!-- Game Results Message -->
        <div class="game-message" id="gameMessage">
            <div class="message-icon" id="messageIcon">
                <i class="fas fa-star"></i>
            </div>
            <div class="message-text" id="messageText">Gewonnen!</div>
            <div class="message-amount">+€<span id="messageAmount">10.00</span></div>
            <button class="btn btn-primary mt-3" onclick="closeGameMessage()">Doorgaan</button>
        </div>

        <!-- Game Info Section -->
        <div class="row mt-5">
            <div class="col-lg-8 mx-auto">
                <div class="card" style="background: var(--bg-card); border: none;">
                    <div class="card-body">
                        <h4 class="card-title mb-4" style="color: var(--text-light);">
                            <i class="fas fa-info-circle"></i> Over Dit Spel
                        </h4>
                        <p style="color: var(--text-light);">@Model.Game.Description</p>

                        <h5 style="color: var(--text-light); margin-top: 2rem; margin-bottom: 1rem;">
                            <i class="fas fa-check-circle"></i> Spelfeatures
                        </h5>
                        <ul style="color: var(--text-light);">
                            <li><strong>Categorie:</strong> @Model.Game.Category</li>
                            <li><strong>Provider:</strong> @Model.Game.Provider</li>
                            <li><strong>RTP:</strong> @Model.Game.RTP.ToString("F1")%</li>
                            <li><strong>Min Inzet:</strong> €@Model.Game.MinBet</li>
                            <li><strong>Max Inzet:</strong> €@Model.Game.MaxBet</li>
                        </ul>

                        @if (Model.Game.Tags.Any())
                        {
                            <h5 style="color: var(--text-light); margin-top: 2rem; margin-bottom: 1rem;">
                                <i class="fas fa-tags"></i> Tags
                            </h5>
                            <div class="mb-3">
                                @foreach (var tag in Model.Game.Tags)
                                {
                                    <span class="badge" style="background: var(--primary-color); color: white; margin-right: 0.5rem; margin-bottom: 0.5rem;">@tag</span>
                                }
                            </div>
                        }

                        <div class="alert alert-info mt-4" role="alert">
                            <i class="fas fa-shield-alt"></i>
                            <strong>Eerlijk en Veilig:</strong> Dit spel gebruikt een gecertificeerde Random Number Generator. Alle resultaten zijn volledig willekeurig.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Responsible Gaming Banner -->
        <div class="row mt-5 mb-5">
            <div class="col-lg-8 mx-auto">
                <div class="alert alert-warning" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Verantwoord Spelen:</strong> Gokken kan verslavend zijn. Speel altijd verantwoord en stel limieten in.
                    <a href="@Url.Action("Index", "Home", new { anchor = "responsible" })" class="alert-link">Meer informatie</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Game functions
    function setBet(amount) {
        document.getElementById('betAmount').value = amount.toFixed(2);
        document.getElementById('totalBet').textContent = amount.toFixed(2);
    }

    function playGame() {
        const betAmount = parseFloat(document.getElementById('betAmount').value);
        const balance = parseFloat(document.getElementById('balance').textContent);

        if (betAmount > balance) {
            alert('Onvoldoende saldo!');
            return;
        }

        const playBtn = document.getElementById('playBtn');
        playBtn.disabled = true;
        playBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Spelen...';

        // Simulate game play
        setTimeout(() => {
            // Random win/loss
            const won = Math.random() > 0.5;
            const multiplier = won ? 2 : 0;
            const winAmount = betAmount * multiplier;
            const newBalance = balance - betAmount + winAmount;

            // Update display
            document.getElementById('balance').textContent = newBalance.toFixed(2);
            document.getElementById('totalWin').textContent = (parseFloat(document.getElementById('totalWin').textContent) + winAmount).toFixed(2);

            // Show message
            if (won) {
                showGameMessage('Gewonnen!', winAmount, 'success');
            } else {
                showGameMessage('Verloren!', 0, 'danger');
            }

            // Reset button
            playBtn.disabled = false;
            playBtn.innerHTML = '<i class="fas fa-play"></i> Start Spel';
        }, 2000);
    }

    function showGameMessage(title, amount, type) {
        const message = document.getElementById('gameMessage');
        const icon = document.getElementById('messageIcon');
        const text = document.getElementById('messageText');
        const msgAmount = document.getElementById('messageAmount');

        text.textContent = title;
        msgAmount.textContent = amount.toFixed(2);

        if (type === 'success') {
            icon.innerHTML = '<i class="fas fa-star" style="color: var(--success-color);"></i>';
        } else {
            icon.innerHTML = '<i class="fas fa-times-circle" style="color: var(--danger-color);"></i>';
        }

        message.classList.add('show');
    }

    function closeGameMessage() {
        document.getElementById('gameMessage').classList.remove('show');
    }
</script>
