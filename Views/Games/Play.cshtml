@model SafeCasino.ViewModels.GameDetailViewModel
@{
    ViewData["Title"] = "Speel " + Model.Game.Name;
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, var(--bg-dark) 0%, #2d0a4e 100%); min-height: 100vh;">
    <div class="row">
        <div class="col-12">
            <!-- Game Header -->
            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-2">
                        <i class="fas fa-gamepad"></i> @Model.Game.Name
                        <span class="badge bg-info">Demo Mode</span>
                    </h2>
                    <p class="text-muted mb-0">
                        <i class="fas fa-coins"></i> Speelgeld: €1.000,00 | RTP: @Model.Game.RTP.ToString("F1")%
                    </p>
                </div>
                <div>
                    <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.Game.Id" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Terug
                    </a>
                </div>
            </div>

            <!-- Game Container -->
            <div class="card" style="background: var(--bg-card); border: 2px solid var(--accent-color); min-height: 600px;">
                <div class="card-body p-5">
                    <div id="game-container" style="width: 100%; height: 500px; display: flex; align-items: center; justify-content: center;">
                        <!-- Game will load here -->
                        <div class="text-center">
                            <div class="spinner-border text-primary mb-3" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p>Game wordt geladen...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Game Controls -->
            <div class="row g-3 mt-4">
                <div class="col-md-4">
                    <div class="card" style="background: var(--bg-card); border: none;">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-coins"></i> Inzet
                            </h5>
                            <div class="input-group">
                                <span class="input-group-text" style="background: var(--bg-dark); border: 1px solid var(--border-color);">€</span>
                                <input type="number" class="form-control" id="bet-amount" value="1" min="0.10" step="0.10"
                                       style="background: var(--bg-dark); border: 1px solid var(--border-color); color: var(--text-light);">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card" style="background: var(--bg-card); border: none;">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-wallet"></i> Saldo
                            </h5>
                            <h3 id="balance" style="color: var(--success-color);">€1.000,00</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card" style="background: var(--bg-card); border: none;">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-trophy"></i> Winst
                            </h5>
                            <h3 id="win-amount" style="color: var(--accent-color);">€0,00</h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="row g-3 mt-3">
                <div class="col-12">
                    <button id="spin-btn" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-play"></i> Spin!
                    </button>
                </div>
            </div>

            <!-- Responsible Gaming Notice -->
            <div class="alert alert-warning mt-5" role="alert">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Demo Mode:</strong> Dit is een demo versie met virtueel geld. Geen echte geld is betrokken.
                Gokken kan verslavend zijn - speel verantwoord!
            </div>
        </div>
    </div>
</div>

<script>
    // Game initialization based on game ID
    const gameId = @Model.Game.Id;
    const gameName = "@Model.Game.Name";

    // Load appropriate game
    document.addEventListener('DOMContentLoaded', function() {
        loadGame(gameId, gameName);
    });

    function loadGame(gameId, gameName) {
        const container = document.getElementById('game-container');

        // Simple slot machine game
        let balance = 1000;
        let winAmount = 0;

        const symbols = ['🍎', '🍊', '🍋', '🍇', '💎', '👑'];
        const reels = [[], [], []];

        // Create reels
        for (let i = 0; i < 3; i++) {
            reels[i] = [];
            for (let j = 0; j < 20; j++) {
                reels[i].push(symbols[Math.floor(Math.random() * symbols.length)]);
            }
        }

        container.innerHTML = `
            <div style="text-align: center;">
                <div style="display: flex; justify-content: center; gap: 20px; margin: 20px 0;">
                    <div id="reel-0" style="width: 100px; height: 150px; background: var(--bg-dark); border: 3px solid var(--accent-color); border-radius: 10px;
                                          font-size: 40px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                        ${symbols[0]}
                    </div>
                    <div id="reel-1" style="width: 100px; height: 150px; background: var(--bg-dark); border: 3px solid var(--accent-color); border-radius: 10px;
                                          font-size: 40px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                        ${symbols[1]}
                    </div>
                    <div id="reel-2" style="width: 100px; height: 150px; background: var(--bg-dark); border: 3px solid var(--accent-color); border-radius: 10px;
                                          font-size: 40px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                        ${symbols[2]}
                    </div>
                </div>
                <p style="font-size: 18px; margin-top: 20px;">Klik op Spin! om te spelen</p>
            </div>
        `;

        // Spin button functionality
        document.getElementById('spin-btn').addEventListener('click', function() {
            const bet = parseFloat(document.getElementById('bet-amount').value);

            if (bet > balance) {
                alert('Onvoldoende saldo!');
                return;
            }

            balance -= bet;
            document.getElementById('balance').textContent = '€' + balance.toFixed(2);

            // Spin animation
            this.disabled = true;
            let spins = 0;
            const spinInterval = setInterval(() => {
                const reel0 = Math.floor(Math.random() * symbols.length);
                const reel1 = Math.floor(Math.random() * symbols.length);
                const reel2 = Math.floor(Math.random() * symbols.length);

                document.getElementById('reel-0').textContent = symbols[reel0];
                document.getElementById('reel-1').textContent = symbols[reel1];
                document.getElementById('reel-2').textContent = symbols[reel2];

                spins++;
                if (spins > 20) {
                    clearInterval(spinInterval);

                    // Check win
                    const finalReel0 = Math.floor(Math.random() * symbols.length);
                    const finalReel1 = Math.floor(Math.random() * symbols.length);
                    const finalReel2 = Math.floor(Math.random() * symbols.length);

                    document.getElementById('reel-0').textContent = symbols[finalReel0];
                    document.getElementById('reel-1').textContent = symbols[finalReel1];
                    document.getElementById('reel-2').textContent = symbols[finalReel2];

                    // Calculate win
                    if (finalReel0 === finalReel1 && finalReel1 === finalReel2) {
                        const multiplier = [5, 10, 20, 50, 100, 200][finalReel0];
                        winAmount = bet * multiplier;
                        balance += winAmount;
                        document.getElementById('win-amount').textContent = '€' + winAmount.toFixed(2);
                        alert('GEWONNEN! 🎉 +€' + winAmount.toFixed(2));
                    } else {
                        winAmount = 0;
                        document.getElementById('win-amount').textContent = '€0,00';
                    }

                    document.getElementById('balance').textContent = '€' + balance.toFixed(2);
                    this.disabled = false;
                }
            }, 50);
        });
    }
</script>
