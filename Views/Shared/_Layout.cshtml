@{
    var currentLanguage = ViewContext.HttpContext.Request.Cookies["language"] ?? "nl";
}

<!DOCTYPE html>
<html lang="@currentLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SafeCasino</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SafeCasino.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">
                    <i class="fas fa-dice-five me-2"></i>
                    SafeCasino
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="fas fa-home me-1"></i>@Localize("Home")
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Games">
                                <i class="fas fa-gamepad me-1"></i>@Localize("Games")
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/FAQ">
                                <i class="fas fa-question-circle me-1"></i>@Localize("FAQ")
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Privacy">
                                <i class="fas fa-shield-alt me-1"></i>@Localize("Privacy")
                            </a>
                        </li>
                    </ul>

                    <!-- Language Switcher -->
                    <div class="d-flex align-items-center me-3">
                        <div class="btn-group" role="group">
                            <a href="/Language/Set/nl" class="btn btn-sm @(currentLanguage == "nl" ? "btn-primary" : "btn-outline-light")">
                                NL
                            </a>
                            <a href="/Language/Set/en" class="btn btn-sm @(currentLanguage == "en" ? "btn-primary" : "btn-outline-light")">
                                EN
                            </a>
                            <a href="/Language/Set/fr" class="btn btn-sm @(currentLanguage == "fr" ? "btn-primary" : "btn-outline-light")">
                                FR
                            </a>
                        </div>
                    </div>

                    <!-- User Menu -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="/Account/Profile">
                                            <i class="fas fa-user me-2"></i>@Localize("Profile")
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/Account/Settings">
                                            <i class="fas fa-cog me-2"></i>@Localize("Settings")
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" action="/Account/Logout" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt me-2"></i>@Localize("Logout")
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>@Localize("Login")
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm ms-2" href="/Account/Register">
                                    <i class="fas fa-user-plus me-1"></i>@Localize("Register")
                                </a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            <div class="row py-4">
                <div class="col-md-4">
                    <h5>SafeCasino</h5>
                    <p class="small">@Localize("FooterTagline")</p>
                </div>
                <div class="col-md-4">
                    <h6>@Localize("QuickLinks")</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/">@Localize("Home")</a></li>
                        <li><a href="/Games">@Localize("Games")</a></li>
                        <li><a href="/About">@Localize("About")</a></li>
                        <li><a href="/Privacy">@Localize("Privacy")</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6>@Localize("Contact")</h6>
                    <p class="small">
                        <i class="fas fa-envelope me-2"></i>info@safecasino.be<br />
                        <i class="fas fa-phone me-2"></i>+32 2 123 45 67
                    </p>
                </div>
            </div>
            <div class="text-center py-3 border-top">
                <small>&copy; 2024 SafeCasino - @Localize("AllRightsReserved")</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
