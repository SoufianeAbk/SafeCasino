<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SafeCasino</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/roulette-styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-dice"></i> SafeCasino
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Games" asp-action="Index">
                                <i class="fas fa-gamepad"></i> Spellen
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-th-large"></i> Categorieën
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li>
                                    <a class="dropdown-item" asp-controller="Games" asp-action="Index" asp-route-category="Slots">
                                        <i class="fas fa-star"></i> Slots
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Games" asp-action="Index" asp-route-category="Roulette">
                                        <i class="fas fa-circle-notch"></i> Roulette
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Games" asp-action="Index" asp-route-category="Blackjack">
                                        <i class="fas fa-heart"></i> Blackjack
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Games" asp-action="Index" asp-route-category="LiveCasino">
                                        <i class="fas fa-video"></i> Live Casino
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Games" asp-action="Index" asp-route-category="Jackpot">
                                        <i class="fas fa-trophy"></i> Jackpot
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="FAQ" asp-action="Index">
                                <i class="fas fa-question-circle"></i> FAQ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Support" asp-action="Index">
                                <i class="fas fa-headset"></i> Support
                            </a>
                        </li>

                        <!-- LANGUAGE SWITCHER BUTTON -->
                        <li class="nav-item dropdown">
                            @{
                                var currentLanguage = Context.Request.Cookies["language"] ?? "nl";
                                var langDisplay = currentLanguage == "en" ? "English" : "Nederlands";
                                var langIcon = currentLanguage == "en" ? "🇬🇧" : "🇳🇱";
                            }
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" title="Taal kiezen">
                                <i class="fas fa-globe"></i>
                                <span id="currentLangDisplay">@langDisplay</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end">
                                <li>
                                    <form method="post" action="@Url.Action("Change", "Language")" style="margin: 0;">
                                        <input type="hidden" name="language" value="nl" />
                                        <input type="hidden" name="returnUrl" value="@(Context.Request.Path)@(Context.Request.QueryString)" />
                                        <button type="submit" class="dropdown-item language-btn @(currentLanguage == "nl" ? "active" : "")" data-lang="nl" style="cursor: pointer; background: none; border: none; text-align: left; width: 100%; padding: 0.5rem 1rem;">
                                            @if (currentLanguage == "nl")
                                            {
                                                <i class="fas fa-check" style="margin-right: 0.5rem; color: var(--success-color);"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-globe" style="margin-right: 0.5rem;"></i>
                                            }
                                            🇳🇱 Nederlands
                                        </button>
                                    </form>
                                </li>
                                <li>
                                    <form method="post" action="@Url.Action("Change", "Language")" style="margin: 0;">
                                        <input type="hidden" name="language" value="en" />
                                        <input type="hidden" name="returnUrl" value="@(Context.Request.Path)@(Context.Request.QueryString)" />
                                        <button type="submit" class="dropdown-item language-btn @(currentLanguage == "en" ? "active" : "")" data-lang="en" style="cursor: pointer; background: none; border: none; text-align: left; width: 100%; padding: 0.5rem 1rem;">
                                            @if (currentLanguage == "en")
                                            {
                                                <i class="fas fa-check" style="margin-right: 0.5rem; color: var(--success-color);"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-globe" style="margin-right: 0.5rem;"></i>
                                            }
                                            🇬🇧 English
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>

                        <!-- LOGIN SECTION - UPDATED FOR LOGIN SYSTEM -->
                        @if (Context.Session.GetString("Username") != null)
                        {
                            <!-- User is logged in -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i>
                                    @{
                                        var email = Context.Session.GetString("Username");
                                        var displayName = email.Split('@')[0];
                                    }
                                    @displayName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fas fa-user-circle"></i> Mijn Profiel
                                        </a>
                                    </li>
                                    @if (Context.Session.GetString("UserType") == "Admin")
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                                <i class="fas fa-shield-alt"></i> Admin Panel
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Games">
                                                <i class="fas fa-gamepad"></i> Games Beheer
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                                <i class="fas fa-users"></i> Users Beheer
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Reports">
                                                <i class="fas fa-chart-bar"></i> Rapporten
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" action="@Url.Action("Logout", "Account")" style="margin: 0;">
                                            <button type="submit" class="dropdown-item" style="cursor: pointer; background: none; border: none; text-align: left; width: 100%; padding: 0.5rem 1rem;">
                                                <i class="fas fa-sign-out-alt"></i> Uitloggen
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- User is not logged in -->
                            <li class="nav-item">
                                <a class="nav-link btn-login" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt"></i> Login
                                </a>
                            </li>
                        }
                        <!-- END LOGIN SECTION -->
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-3 mb-4">
                    <h5><i class="fas fa-dice"></i> SafeCasino</h5>
                    <p class="text-muted">Jouw veilige en betrouwbare online casino met de beste spellen en hoogste uitbetalingen.</p>
                    <div class="social-links">
                        <a href="#" class="me-3"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-twitter fa-lg"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#"><i class="fab fa-youtube fa-lg"></i></a>
                    </div>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Casino Spellen</h5>
                    <ul>
                        <li><a asp-controller="Games" asp-action="Index" asp-route-category="Slots">Slots</a></li>
                        <li><a asp-controller="Games" asp-action="Index" asp-route-category="Roulette">Roulette</a></li>
                        <li><a asp-controller="Games" asp-action="Index" asp-route-category="Blackjack">Blackjack</a></li>
                        <li><a asp-controller="Games" asp-action="Index" asp-route-category="LiveCasino">Live Casino</a></li>
                        <li><a asp-controller="Games" asp-action="Index" asp-route-category="Jackpot">Jackpot</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Informatie</h5>
                    <ul>
                        <li><a asp-controller="Home" asp-action="About">Over Ons</a></li>
                        <li><a asp-controller="FAQ" asp-action="Index">Veelgestelde Vragen</a></li>
                        <li><a asp-controller="Support" asp-action="Index">Klantenservice</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Verantwoord Spelen</a></li>
                        <li><a asp-controller="Home" asp-action="Terms">Algemene Voorwaarden</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Contact</h5>
                    <ul>
                        <li><i class="fas fa-envelope"></i> support@safecasino.be</li>
                        <li><i class="fas fa-phone"></i> +32 2 123 45 67</li>
                        <li><i class="fas fa-clock"></i> 24/7 beschikbaar</li>
                    </ul>
                    <h5 class="mt-3">Veilig & Betrouwbaar</h5>
                    <p class="text-muted small">
                        <i class="fas fa-shield-alt"></i> SSL Beveiligd<br>
                        <i class="fas fa-check-circle"></i> Vergunning nr. 12345
                    </p>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="row">
                    <div class="col-md-6">
                        <p>&copy; @DateTime.Now.Year SafeCasino. Alle rechten voorbehouden.</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a> |
                        <a asp-controller="Home" asp-action="Terms">Disclaimer</a> |
                        <a href="#">Cookies</a>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 text-center">
                        <p class="small text-muted">
                            <i class="fas fa-exclamation-triangle"></i> Gokken kan verslavend zijn. Speel verantwoord. 18+
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/roulette-game.js" asp-append-version="true"></script>
    <script src="~/js/language-switcher.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
