@{
    ViewData["Title"] = "Home";
    var popularGames = ViewData["PopularGames"] as List<SafeCasino.Models.Game> ?? new List<SafeCasino.Models.Game>();
    var newGames = ViewData["NewGames"] as List<SafeCasino.Models.Game> ?? new List<SafeCasino.Models.Game>();
    var jackpotGames = ViewData["JackpotGames"] as List<SafeCasino.Models.Game> ?? new List<SafeCasino.Models.Game>();
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <h1>SafeCasino</h1>
        <p>@Localize("DiscoverGames")</p>
        <a asp-controller="Games" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="fas fa-play"></i> @Localize("BeginPlaying")
        </a>
    </div>
</div>

<!-- Featured Banners -->
<div class="container featured-banners">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="banner-card" style="background: linear-gradient(135deg, #9333ea 0%, #ec4899 100%);">
                <div class="banner-content">
                    <h3>€10 @Localize("Bonus")</h3>
                    <p>@Localize("DailyBonus")</p>
                    <button class="btn">@Localize("PlayNow")</button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="banner-card" style="background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);">
                <div class="banner-content">
                    <h3>@Localize("Jackpot")</h3>
                    <p>€180.000+ @Localize("PrizePool")</p>
                    <button class="btn">@Localize("MoreInfo")</button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="banner-card" style="background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);">
                <div class="banner-content">
                    <h3>@Localize("LiveCasino")</h3>
                    <p>@Localize("RealDealers")</p>
                    <button class="btn">@Localize("PlayNow")</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Category Section -->
<div class="container category-section">
    <h2 class="section-title text-center">@Localize("ChooseCategory")</h2>
    <div class="category-grid">
        <a asp-controller="Games" asp-action="Index" asp-route-category="Slots" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-star"></i>
            </div>
            <div class="category-name">@Localize("Slots")</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="Roulette" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-circle-notch"></i>
            </div>
            <div class="category-name">@Localize("Roulette")</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="Blackjack" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-heart"></i>
            </div>
            <div class="category-name">@Localize("Blackjack")</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="LiveCasino" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-video"></i>
            </div>
            <div class="category-name">@Localize("LiveCasino")</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="Jackpot" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-trophy"></i>
            </div>
            <div class="category-name">@Localize("Jackpot")</div>
        </a>
    </div>
</div>

<!-- Popular Games -->
@if (popularGames.Any())
{
    <div class="container games-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title mb-0">@Localize("PopularGames")</h2>
            <a asp-controller="Games" asp-action="Popular" class="btn btn-secondary">@Localize("ViewAll")</a>
        </div>
        <div class="row g-4">
            @foreach (var game in popularGames)
            {
                <div class="col-md-4">
                    <div class="game-card fade-in">
                        <img src="@game.ThumbnailUrl" alt="@game.Name" class="game-image" />
                        <div class="game-info">
                            <h5 class="game-title">@game.Name</h5>
                            <p class="game-provider">@game.Provider</p>
                            <div class="game-badges">
                                @if (game.IsPopular)
                                {
                                    <span class="badge badge-popular">@Localize("Popular")</span>
                                }
                                @if (game.IsNew)
                                {
                                    <span class="badge badge-new">@Localize("New")</span>
                                }
                                @if (game.HasJackpot)
                                {
                                    <span class="badge badge-jackpot">@Localize("Jackpot")</span>
                                }
                            </div>
                            <button class="game-play-btn" onclick="location.href='@Url.Action("Details", "Games", new { id = game.Id })'">
                                <i class="fas fa-play"></i> @Localize("PlayNow")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- New Games -->
@if (newGames.Any())
{
    <div class="container games-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title mb-0">@Localize("NewGames")</h2>
            <a asp-controller="Games" asp-action="New" class="btn btn-secondary">@Localize("ViewAll")</a>
        </div>
        <div class="row g-4">
            @foreach (var game in newGames)
            {
                <div class="col-md-4">
                    <div class="game-card fade-in">
                        <img src="@game.ThumbnailUrl" alt="@game.Name" class="game-image" />
                        <div class="game-info">
                            <h5 class="game-title">@game.Name</h5>
                            <p class="game-provider">@game.Provider</p>
                            <div class="game-badges">
                                <span class="badge badge-new">@Localize("New")</span>
                                @if (game.HasJackpot)
                                {
                                    <span class="badge badge-jackpot">@Localize("Jackpot")</span>
                                }
                            </div>
                            <button class="game-play-btn" onclick="location.href='@Url.Action("Details", "Games", new { id = game.Id })'">
                                <i class="fas fa-play"></i> @Localize("PlayNow")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Jackpot Games -->
@if (jackpotGames.Any())
{
    <div class="container games-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title mb-0">
                <i class="fas fa-trophy"></i> @Localize("JackpotGames")
            </h2>
            <a asp-controller="Games" asp-action="Jackpot" class="btn btn-secondary">@Localize("ViewAll")</a>
        </div>
        <div class="row g-4">
            @foreach (var game in jackpotGames)
            {
                <div class="col-md-4">
                    <div class="game-card fade-in">
                        <img src="@game.ThumbnailUrl" alt="@game.Name" class="game-image" />
                        <div class="game-info">
                            <h5 class="game-title">@game.Name</h5>
                            <p class="game-provider">@game.Provider</p>
                            <div class="game-badges">
                                <span class="badge badge-jackpot">@Localize("Jackpot")</span>
                            </div>
                            <button class="game-play-btn" onclick="location.href='@Url.Action("Details", "Games", new { id = game.Id })'">
                                <i class="fas fa-play"></i> @Localize("PlayNow")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Features Section -->
<div class="container py-5">
    <div class="row g-4 text-center">
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-shield-alt fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>@Localize("SafeAndTrusted")</h5>
                <p class="text-muted">@Localize("SafeTransactions")</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-headset fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>@Localize("Support24_7")</h5>
                <p class="text-muted">@Localize("AlwaysAvailable")</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-bolt fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>@Localize("FastPayouts")</h5>
                <p class="text-muted">@Localize("ReceiveWinnings")</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-mobile-alt fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>@Localize("MobileFriendly")</h5>
                <p class="text-muted">@Localize("PlayAnywhere")</p>
            </div>
        </div>
    </div>
</div>
