@{
    ViewData["Title"] = Localize("Home");
}

<div class="home-container">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="hero-title">
                        @Localize("WelcomeToSafeCasino")
                    </h1>
                    <p class="hero-subtitle">
                        @Localize("HeroDescription")
                    </p>
                    <div class="hero-buttons">
                        <a href="/Account/Register" class="btn btn-primary">
                            <i class="fas fa-user-plus me-2"></i>@Localize("GetStarted")
                        </a>
                        <a href="/Games" class="btn btn-outline-light">
                            <i class="fas fa-gamepad me-2"></i>@Localize("PlayNow")
                        </a>
                    </div>
                </div>
                <div class="col-lg-6 text-center d-none d-lg-block">
                    <div class="hero-image">
                        <i class="fas fa-dice-five"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
        <div class="container">
            <h2 class="section-title">@Localize("WhyChooseUs")</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h4>@Localize("SafeAndSecure")</h4>
                        <p>@Localize("SafeDescription")</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <h4>@Localize("FastPayouts")</h4>
                        <p>@Localize("PayoutsDescription")</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-headset"></i>
                        </div>
                        <h4>@Localize("Support247")</h4>
                        <p>@Localize("SupportDescription")</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Popular Games Section -->
    <section class="games-section">
        <div class="container">
            <h2 class="section-title">@Localize("PopularGames")</h2>
            <div class="games-grid">
                <div class="game-card">
                    <div class="game-icon">
                        <i class="fas fa-circle-notch"></i>
                    </div>
                    <h3>@Localize("Roulette")</h3>
                    <p>@Localize("RouletteDescription")</p>
                    <a href="/Games" class="btn btn-sm btn-primary">
                        @Localize("PlayNow") <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="game-card">
                    <div class="game-icon">
                        <i class="fas fa-coins"></i>
                    </div>
                    <h3>@Localize("Slots")</h3>
                    <p>@Localize("SlotsDescription")</p>
                    <a href="/Games" class="btn btn-sm btn-primary">
                        @Localize("PlayNow") <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="game-card">
                    <div class="game-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h3>@Localize("Blackjack")</h3>
                    <p>@Localize("BlackjackDescription")</p>
                    <a href="/Games" class="btn btn-sm btn-primary">
                        @Localize("PlayNow") <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3 col-6">
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <h4>10K+</h4>
                        <p>@Localize("ActivePlayers")</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-gamepad"></i>
                        </div>
                        <h4>50+</h4>
                        <p>@Localize("Games")</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-trophy"></i>
                        </div>
                        <h4>€1M+</h4>
                        <p>@Localize("PaidOut")</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-card">
                        <div class="stat-icon">
                            <i class="fas fa-star"></i>
                        </div>
                        <h4>4.8★</h4>
                        <p>@Localize("Rating")</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container text-center">
            <h2 class="cta-title">@Localize("ReadyToStart")</h2>
            <p class="cta-subtitle">@Localize("CTADescription")</p>
            <a href="/Account/Register" class="btn btn-light btn-lg">
                <i class="fas fa-rocket me-2"></i>@Localize("JoinNow")
            </a>
        </div>
    </section>
</div>
