@{
    ViewData["Title"] = "Home";
    var popularGames = ViewData["PopularGames"] as List<SafeCasino.Models.Game> ?? new List<SafeCasino.Models.Game>();
    var newGames = ViewData["NewGames"] as List<SafeCasino.Models.Game> ?? new List<SafeCasino.Models.Game>();
    var jackpotGames = ViewData["JackpotGames"] as List<SafeCasino.Models.Game> ?? new List<SafeCasino.Models.Game>();
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <h1>Welkom bij SafeCasino</h1>
        <p>Ontdek meer dan 50 spannende casino spellen!</p>
        <a asp-controller="Games" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="fas fa-play"></i> Begin met Spelen
        </a>
    </div>
</div>

<!-- Featured Banners -->
<div class="container featured-banners">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="banner-card" style="background: linear-gradient(135deg, #9333ea 0%, #ec4899 100%);">
                <div class="banner-content">
                    <h3>€10 GRATIS</h3>
                    <p>Dagelijkse Bonus</p>
                    <button class="btn">SPEEL NU</button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="banner-card" style="background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);">
                <div class="banner-content">
                    <h3>JACKPOT</h3>
                    <p>€180.000+ Prijs Pool</p>
                    <button class="btn">MEER INFO</button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="banner-card" style="background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);">
                <div class="banner-content">
                    <h3>LIVE CASINO</h3>
                    <p>Echte Dealers</p>
                    <button class="btn">SPEEL NU</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Category Section -->
<div class="container category-section">
    <h2 class="section-title text-center">Kies Je Categorie</h2>
    <div class="category-grid">
        <a asp-controller="Games" asp-action="Index" asp-route-category="Slots" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-star"></i>
            </div>
            <div class="category-name">Slots</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="Roulette" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-circle-notch"></i>
            </div>
            <div class="category-name">Roulette</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="Blackjack" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-heart"></i>
            </div>
            <div class="category-name">Blackjack</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="LiveCasino" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-video"></i>
            </div>
            <div class="category-name">Live Casino</div>
        </a>
        <a asp-controller="Games" asp-action="Index" asp-route-category="Jackpot" class="text-decoration-none">
            <div class="category-icon">
                <i class="fas fa-trophy"></i>
            </div>
            <div class="category-name">Jackpot</div>
        </a>
    </div>
</div>

<!-- Popular Games -->
@if (popularGames.Any())
{
    <div class="container games-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title mb-0">Populaire Spellen</h2>
            <a asp-controller="Games" asp-action="Popular" class="btn btn-secondary">Bekijk Alle</a>
        </div>
        <div class="games-grid">
            @foreach (var game in popularGames)
            {
                <div class="game-card fade-in">
                    <img src="@game.ThumbnailUrl" alt="@game.Name" class="game-image" />
                    <div class="game-info">
                        <h5 class="game-title">@game.Name</h5>
                        <p class="game-provider">@game.Provider</p>
                        <div class="game-badges">
                            @if (game.IsPopular)
                            {
                                <span class="badge badge-popular">POPULAIR</span>
                            }
                            @if (game.IsNew)
                            {
                                <span class="badge badge-new">NIEUW</span>
                            }
                            @if (game.HasJackpot)
                            {
                                <span class="badge badge-jackpot">JACKPOT</span>
                            }
                        </div>
                        <button class="game-play-btn" onclick="location.href='@Url.Action("Details", "Games", new { id = game.Id })'">
                            <i class="fas fa-play"></i> Speel Nu
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- New Games -->
@if (newGames.Any())
{
    <div class="container games-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title mb-0">Nieuwe Spellen</h2>
            <a asp-controller="Games" asp-action="New" class="btn btn-secondary">Bekijk Alle</a>
        </div>
        <div class="games-grid">
            @foreach (var game in newGames)
            {
                <div class="game-card fade-in">
                    <img src="@game.ThumbnailUrl" alt="@game.Name" class="game-image" />
                    <div class="game-info">
                        <h5 class="game-title">@game.Name</h5>
                        <p class="game-provider">@game.Provider</p>
                        <div class="game-badges">
                            <span class="badge badge-new">NIEUW</span>
                            @if (game.HasJackpot)
                            {
                                <span class="badge badge-jackpot">JACKPOT</span>
                            }
                        </div>
                        <button class="game-play-btn" onclick="location.href='@Url.Action("Details", "Games", new { id = game.Id })'">
                            <i class="fas fa-play"></i> Speel Nu
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Jackpot Games -->
@if (jackpotGames.Any())
{
    <div class="container games-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title mb-0">
                <i class="fas fa-trophy"></i> Jackpot Spellen
            </h2>
            <a asp-controller="Games" asp-action="Jackpot" class="btn btn-secondary">Bekijk Alle</a>
        </div>
        <div class="row g-4">
            @foreach (var game in jackpotGames)
            {
                <div class="col-md-4">
                    <div class="game-card fade-in">
                        <img src="@game.ThumbnailUrl" alt="@game.Name" class="game-image" />
                        <div class="game-info">
                            <h5 class="game-title">@game.Name</h5>
                            <p class="game-provider">@game.Provider</p>
                            <div class="game-badges">
                                <span class="badge badge-jackpot">JACKPOT</span>
                            </div>
                            <button class="game-play-btn" onclick="location.href='@Url.Action("Details", "Games", new { id = game.Id })'">
                                <i class="fas fa-play"></i> Speel Nu
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Features Section -->
<div class="container py-5">
    <div class="row g-4 text-center">
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-shield-alt fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>Veilig & Betrouwbaar</h5>
                <p class="text-muted">100% veilige transacties met SSL encryptie</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-headset fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>24/7 Support</h5>
                <p class="text-muted">Altijd bereikbaar voor jouw vragen</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-bolt fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>Snelle Uitbetalingen</h5>
                <p class="text-muted">Ontvang je winst binnen 24 uur</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="feature-card">
                <i class="fas fa-mobile-alt fa-3x mb-3" style="color: var(--primary-color);"></i>
                <h5>Mobiel Vriendelijk</h5>
                <p class="text-muted">Speel overal en altijd op je mobiel</p>
            </div>
        </div>
    </div>
</div>
