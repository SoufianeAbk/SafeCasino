@{
    ViewData["Title"] = Html.Localize("FAQ");
}

<div class="container py-5">
    <h1 class="section-title text-center mb-5">
        <i class="fas fa-question-circle"></i> @Html.Localize("FAQ")
    </h1>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Account & Registratie -->
            <h3 class="mb-4" style="color: var(--primary-color);">
                <i class="fas fa-user"></i> @Html.Localize("AccountRegistration")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("HowToCreateAccount")
                </div>
                <div class="faq-answer">
                    @Html.Localize("ClickRegisterAndFillForm"). @Html.Localize("MustBe18Years"). @Html.Localize("ReceiveConfirmationEmail").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("CanIHaveMultipleAccounts")
                </div>
                <div class="faq-answer">
                    @Html.Localize("NoMultipleAccountsAllowed"). @Html.Localize("MultipleAccountsSuspension").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("HowToResetPassword")
                </div>
                <div class="faq-answer">
                    @Html.Localize("ClickForgotPasswordAndEmail"). @Html.Localize("ReceiveResetLink").
                </div>
            </div>

            <!-- Storten & Opnemen -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-wallet"></i> @Html.Localize("DepositsWithdrawals")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("WhichPaymentMethods")
                </div>
                <div class="faq-answer">
                    @Html.Localize("WeAcceptPaymentMethods"):
                    <ul class="mt-2">
                        <li>@Html.Localize("CreditCards") (Visa, Mastercard)</li>
                        <li>Bancontact</li>
                        <li>PayPal</li>
                        <li>@Html.Localize("BankTransfer")</li>
                        <li>Skrill</li>
                        <li>Neteller</li>
                    </ul>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("MinMaxDepositAmount")
                </div>
                <div class="faq-answer">
                    @Html.Localize("MinimumDeposit10Euro"). @Html.Localize("MaximumVariesByMethod").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("WithdrawalProcessingTime")
                </div>
                <div class="faq-answer">
                    @Html.Localize("WithdrawalsProcessedWithin24Hours"). @Html.Localize("ProcessingTimeVaries"):
                    <ul class="mt-2">
                        <li>@Html.Localize("EWallets") (PayPal, Skrill): 0-24 @Html.Localize("Hours")</li>
                        <li>@Html.Localize("CreditCard"): 3-5 @Html.Localize("WorkingDays")</li>
                        <li>@Html.Localize("BankTransfer"): 3-7 @Html.Localize("WorkingDays")</li>
                    </ul>
                </div>
            </div>

            <!-- Spellen & Gameplay -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-gamepad"></i> @Html.Localize("GamesGameplay")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("CanIPlayGamesFree")
                </div>
                <div class="faq-answer">
                    @Html.Localize("YesPlayDemoMode"). @Html.Localize("TryGamesBefore").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("WhatIsRTP")
                </div>
                <div class="faq-answer">
                    @Html.Localize("RTPDefinition"). @Html.Localize("RTPExplanation").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("AreGamesFair")
                </div>
                <div class="faq-answer">
                    @Html.Localize("GamesUseCertifiedRNG"). @Html.Localize("GuaranteesFairResults").
                </div>
            </div>

            <!-- Bonussen & Promoties -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-gift"></i> @Html.Localize("BonusesPromotions")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("WhatAreWagering")
                </div>
                <div class="faq-answer">
                    @Html.Localize("WageringDefinition"). @Html.Localize("WageringExample").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("CanIDeclineBonus")
                </div>
                <div class="faq-answer">
                    @Html.Localize("YesCanDeclineBonus"). @Html.Localize("ContactSupportToRemove").
                </div>
            </div>

            <!-- Veiligheid & Verantwoord Spelen -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-shield-alt"></i> @Html.Localize("SecurityResponsibleGaming")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("HowProtectPersonalData")
                </div>
                <div class="faq-answer">
                    @Html.Localize("WeUseSSLEncryption"). @Html.Localize("DataNotShared").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("CanISetLimits")
                </div>
                <div class="faq-answer">
                    @Html.Localize("YesEncourageResponsiblePlay"). @Html.Localize("CanSetLimits"):
                    <ul class="mt-2">
                        <li>@Html.Localize("DailyWeeklyMonthlyLimits")</li>
                        <li>@Html.Localize("BettingLimitsPerSession")</li>
                        <li>@Html.Localize("LossLimits")</li>
                        <li>@Html.Localize("TimeoutPeriods")</li>
                        <li>@Html.Localize("SelfExclusion")</li>
                    </ul>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Html.Localize("WhatIfGamblingProblem")
                </div>
                <div class="faq-answer">
                    @Html.Localize("SeveralOrganizationsCanHelp"):
                    <ul class="mt-2">
                        <li>@Html.Localize("HelplineLoketKansspelen"): 0800 35 777</li>
                        <li>GambleAware: www.gambleaware.be</li>
                        <li>@Html.Localize("AnonymousGamblers"): www.ag-belgium.be</li>
                    </ul>
                    @Html.Localize("ContactUsToCloseAccount").
                </div>
            </div>
        </div>
    </div>

    <!-- Contact CTA -->
    <div class="text-center mt-5 p-5" style="background: var(--bg-card); border-radius: 12px;">
        <h3 class="mb-3">@Html.Localize("QuestionNotAnswered")</h3>
        <p class="text-muted mb-4">@Html.Localize("SupportTeam24_7")</p>
        <a asp-controller="Support" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="fas fa-headset"></i> @Html.Localize("ContactUs")
        </a>
    </div>
</div>
