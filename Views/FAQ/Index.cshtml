@{
    ViewData["Title"] = Localize("FAQ");
}

<div class="container py-5">
    <h1 class="section-title text-center mb-5">
        <i class="fas fa-question-circle"></i> @Localize("FAQ")
    </h1>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Account & Registratie -->
            <h3 class="mb-4" style="color: var(--primary-color);">
                <i class="fas fa-user"></i> @Localize("AccountRegistration")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("HowToCreateAccount")
                </div>
                <div class="faq-answer">
                    @Localize("ClickRegisterAndFillForm"). @Localize("MustBe18Years"). @Localize("ReceiveConfirmationEmail").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("CanIHaveMultipleAccounts")
                </div>
                <div class="faq-answer">
                    @Localize("NoMultipleAccountsAllowed"). @Localize("MultipleAccountsSuspension").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("HowToResetPassword")
                </div>
                <div class="faq-answer">
                    @Localize("ClickForgotPasswordAndEmail"). @Localize("ReceiveResetLink").
                </div>
            </div>

            <!-- Storten & Opnemen -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-wallet"></i> @Localize("DepositsWithdrawals")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("WhichPaymentMethods")
                </div>
                <div class="faq-answer">
                    @Localize("WeAcceptPaymentMethods"):
                    <ul class="mt-2">
                        <li>@Localize("CreditCards") (Visa, Mastercard)</li>
                        <li>Bancontact</li>
                        <li>PayPal</li>
                        <li>@Localize("BankTransfer")</li>
                        <li>Skrill</li>
                        <li>Neteller</li>
                    </ul>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("MinMaxDepositAmount")
                </div>
                <div class="faq-answer">
                    @Localize("MinimumDeposit10Euro"). @Localize("MaximumVariesByMethod").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("WithdrawalProcessingTime")
                </div>
                <div class="faq-answer">
                    @Localize("WithdrawalsProcessedWithin24Hours"). @Localize("ProcessingTimeVaries"):
                    <ul class="mt-2">
                        <li>@Localize("EWallets") (PayPal, Skrill): 0-24 @Localize("Hours")</li>
                        <li>@Localize("CreditCard"): 3-5 @Localize("WorkingDays")</li>
                        <li>@Localize("BankTransfer"): 3-7 @Localize("WorkingDays")</li>
                    </ul>
                </div>
            </div>

            <!-- Spellen & Gameplay -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-gamepad"></i> @Localize("GamesGameplay")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("CanIPlayGamesFree")
                </div>
                <div class="faq-answer">
                    @Localize("YesPlayDemoMode"). @Localize("TryGamesBefore").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("WhatIsRTP")
                </div>
                <div class="faq-answer">
                    @Localize("RTPDefinition"). @Localize("RTPExplanation").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("AreGamesFair")
                </div>
                <div class="faq-answer">
                    @Localize("GamesUseCertifiedRNG"). @Localize("GuaranteesFairResults").
                </div>
            </div>

            <!-- Bonussen & Promoties -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-gift"></i> @Localize("BonusesPromotions")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("WhatAreWagering")
                </div>
                <div class="faq-answer">
                    @Localize("WageringDefinition"). @Localize("WageringExample").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("CanIDeclineBonus")
                </div>
                <div class="faq-answer">
                    @Localize("YesCanDeclineBonus"). @Localize("ContactSupportToRemove").
                </div>
            </div>

            <!-- Veiligheid & Verantwoord Spelen -->
            <h3 class="mb-4 mt-5" style="color: var(--primary-color);">
                <i class="fas fa-shield-alt"></i> @Localize("SecurityResponsibleGaming")
            </h3>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("HowProtectPersonalData")
                </div>
                <div class="faq-answer">
                    @Localize("WeUseSSLEncryption"). @Localize("DataNotShared").
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("CanISetLimits")
                </div>
                <div class="faq-answer">
                    @Localize("YesEncourageResponsiblePlay"). @Localize("CanSetLimits"):
                    <ul class="mt-2">
                        <li>@Localize("DailyWeeklyMonthlyLimits")</li>
                        <li>@Localize("BettingLimitsPerSession")</li>
                        <li>@Localize("LossLimits")</li>
                        <li>@Localize("TimeoutPeriods")</li>
                        <li>@Localize("SelfExclusion")</li>
                    </ul>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <i class="fas fa-check-circle" style="color: var(--success-color);"></i>
                    @Localize("WhatIfGamblingProblem")
                </div>
                <div class="faq-answer">
                    @Localize("SeveralOrganizationsCanHelp"):
                    <ul class="mt-2">
                        <li>@Localize("HelplineLoketKansspelen"): 0800 35 777</li>
                        <li>GambleAware: www.gambleaware.be</li>
                        <li>@Localize("AnonymousGamblers"): www.ag-belgium.be</li>
                    </ul>
                    @Localize("ContactUsToCloseAccount").
                </div>
            </div>
        </div>
    </div>

    <!-- Contact CTA -->
    <div class="text-center mt-5 p-5" style="background: var(--bg-card); border-radius: 12px;">
        <h3 class="mb-3">@Localize("QuestionNotAnswered")</h3>
        <p class="text-muted mb-4">@Localize("SupportTeam24_7")</p>
        <a asp-controller="Support" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="fas fa-headset"></i> @Localize("ContactUs")
        </a>
    </div>
</div>
