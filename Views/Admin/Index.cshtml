@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-5">
    <!-- Admin Header -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="mb-0">
                        <i class="fas fa-shield-alt"></i> Admin Dashboard
                    </h1>
                    <p class="text-muted mb-0">Welkom, @ViewData["Username"]</p>
                </div>
                <div>
                    <span class="badge bg-success me-2">
                        <i class="fas fa-circle-notch"></i> Online
                    </span>
                    <form method="post" action="@Url.Action("Logout", "Admin")" style="display: inline;">
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2">Actieve Spelers</p>
                            <h3 style="color: var(--primary-color);">1,250</h3>
                        </div>
                        <i class="fas fa-users fa-2x text-muted"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2">Casino Spellen</p>
                            <h3 style="color: var(--success-color);">50</h3>
                        </div>
                        <i class="fas fa-gamepad fa-2x text-muted"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2">Totale Inkomsten</p>
                            <h3 style="color: var(--accent-color);">€12,500</h3>
                        </div>
                        <i class="fas fa-euro-sign fa-2x text-muted"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-2">Systeem Status</p>
                            <h3 style="color: var(--success-color);">OK</h3>
                        </div>
                        <i class="fas fa-server fa-2x text-muted"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Menu -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <a href="@Url.Action("Games", "Admin")" class="text-decoration-none">
                <div class="card admin-menu-card" style="background: var(--bg-card); border: none; cursor: pointer;">
                    <div class="card-body text-center p-5">
                        <i class="fas fa-gamepad fa-3x mb-3" style="color: var(--primary-color);"></i>
                        <h5>Spellen Beheer</h5>
                        <p class="text-muted small mb-0">Manage alle casino games</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="@Url.Action("Users", "Admin")" class="text-decoration-none">
                <div class="card admin-menu-card" style="background: var(--bg-card); border: none; cursor: pointer;">
                    <div class="card-body text-center p-5">
                        <i class="fas fa-users fa-3x mb-3" style="color: var(--accent-color);"></i>
                        <h5>Gebruikers Beheer</h5>
                        <p class="text-muted small mb-0">Manage user accounts</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="@Url.Action("Reports", "Admin")" class="text-decoration-none">
                <div class="card admin-menu-card" style="background: var(--bg-card); border: none; cursor: pointer;">
                    <div class="card-body text-center p-5">
                        <i class="fas fa-chart-bar fa-3x mb-3" style="color: var(--success-color);"></i>
                        <h5>Rapporten</h5>
                        <p class="text-muted small mb-0">View analytics and reports</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="@Url.Action("Settings", "Admin")" class="text-decoration-none">
                <div class="card admin-menu-card" style="background: var(--bg-card); border: none; cursor: pointer;">
                    <div class="card-body text-center p-5">
                        <i class="fas fa-cog fa-3x mb-3" style="color: var(--secondary-color);"></i>
                        <h5>Instellingen</h5>
                        <p class="text-muted small mb-0">System configuration</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <h5 class="card-title mb-4">
                        <i class="fas fa-history"></i> Recente Activiteit
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-dark table-borderless">
                            <thead>
                                <tr style="border-bottom: 1px solid var(--border-color);">
                                    <th>Gebruiker</th>
                                    <th>Actie</th>
                                    <th>Tijd</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr style="border-bottom: 1px solid var(--border-color);">
                                    <td>user@example.com</td>
                                    <td>Login</td>
                                    <td>2 minuten geleden</td>
                                    <td><span class="badge bg-success">OK</span></td>
                                </tr>
                                <tr style="border-bottom: 1px solid var(--border-color);">
                                    <td>admin@example.com</td>
                                    <td>Game bewerkt</td>
                                    <td>15 minuten geleden</td>
                                    <td><span class="badge bg-info">Info</span></td>
                                </tr>
                                <tr style="border-bottom: 1px solid var(--border-color);">
                                    <td>player@example.com</td>
                                    <td>Betaling ontvangen</td>
                                    <td>1 uur geleden</td>
                                    <td><span class="badge bg-success">OK</span></td>
                                </tr>
                                <tr>
                                    <td>user2@example.com</td>
                                    <td>Account aangemaakt</td>
                                    <td>2 uren geleden</td>
                                    <td><span class="badge bg-success">OK</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Info -->
        <div class="col-lg-4">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body">
                    <h5 class="card-title mb-4">
                        <i class="fas fa-server"></i> Systeem Info
                    </h5>
                    <div class="mb-3">
                        <small class="text-muted d-block">Framework</small>
                        <strong>.NET 8.0</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Database</small>
                        <strong>SQL Server</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Version</small>
                        <strong>2.1.0</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Uptime</small>
                        <strong>45 dagen</strong>
                    </div>
                    <hr style="border-color: var(--border-color);">
                    <div class="alert alert-success mb-0" role="alert">
                        <i class="fas fa-check-circle"></i> Alle systemen operationeel
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-menu-card {
        transition: all 0.3s ease;
        border-left: 4px solid transparent !important;
    }

    .admin-menu-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(147, 51, 234, 0.3);
        border-left-color: var(--primary-color) !important;
    }

    .table-dark tbody tr:hover {
        background-color: rgba(147, 51, 234, 0.1);
    }
</style>
