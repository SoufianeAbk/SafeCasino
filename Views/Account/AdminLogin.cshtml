@model SafeCasino.Models.AdminLoginRequest
@{
    ViewData["Title"] = "Admin Login";
    var lang = Context.Request.Cookies["language"] ?? "nl";
}

<div class="admin-login-container">
    <div class="login-card">
        <h1 class="text-center mb-4">@localizationService.GetString("AdminLogin", lang)</h1>

        @if (ViewData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <strong>@localizationService.GetString("Error", lang):</strong> @ViewData["ErrorMessage"]
            </div>
        }

        <form method="post" action="/Admin/Login">
            <div class="mb-3">
                <label class="form-label">@localizationService.GetString("Username", lang)</label>
                <input type="text" name="Username" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">@localizationService.GetString("Password", lang)</label>
                <input type="password" name="Password" class="form-control" required />
            </div>

            <div class="mb-3">
                <input type="checkbox" name="RememberMe" class="form-check-input" id="remember" />
                <label class="form-check-label" for="remember">@localizationService.GetString("RememberMe", lang)</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">@localizationService.GetString("Login", lang)</button>
        </form>

        <hr />
        <p class="text-center">
            <a href="/">@localizationService.GetString("BackToHome", lang)</a>
        </p>
    </div>

    <div class="language-switcher">
        <a href="/Language/Set/nl" class="btn btn-sm btn-outline-light">NL</a>
        <a href="/Language/Set/en" class="btn btn-sm btn-outline-light">EN</a>
    </div>
</div>

<style>
    .admin-login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
    }

    .login-card {
        background: white;
        border-radius: 15px;
        padding: 40px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
    }

    .language-switcher {
        position: absolute;
        top: 20px;
        right: 20px;
    }

        .language-switcher .btn {
            margin-left: 5px;
        }
</style>
