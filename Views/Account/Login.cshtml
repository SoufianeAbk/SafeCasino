@{
    ViewData["Title"] = @Localize("SignIn");
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <div class="card" style="background: var(--bg-card); border: none;">
                <div class="card-body p-5">
                    <!-- Header -->
                    <div class="text-center mb-5">
                        <i class="fas fa-dice fa-4x mb-3" style="color: var(--primary-color);"></i>
                        <h2 class="card-title mb-2">SafeCasino @Localize("Login")</h2>
                        <p class="text-muted">@Localize("WelcomeBack")! @Localize("SignInToPlay")</p>
                    </div>

                    <!-- Error Message -->
                    @if (!string.IsNullOrEmpty(ViewData["ErrorMessage"]?.ToString()))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @ViewData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Login Form -->
                    <form method="post" action="@Url.Action("Login", "Account")">
                        <!-- Username/Email -->
                        <div class="mb-4">
                            <label for="username" class="form-label">
                                <i class="fas fa-user"></i> @Localize("UsernameEmail")
                            </label>
                            <input type="email"
                                   class="form-control form-control-lg"
                                   id="username"
                                   name="username"
                                   placeholder="casinouser@ehb.be"
                                   required
                                   autocomplete="email"
                                   value="casinouser@ehb.be">
                            <small class="text-muted mt-1 d-block">
                                <i class="fas fa-info-circle"></i> @Localize("Demo"): casinouser@ehb.be
                            </small>
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label for="password" class="form-label">
                                <i class="fas fa-lock"></i> @Localize("Password")
                            </label>
                            <input type="password"
                                   class="form-control form-control-lg"
                                   id="password"
                                   name="password"
                                   placeholder="@Localize("EnterPassword")"
                                   required
                                   autocomplete="current-password"
                                   value="User!321">
                            <small class="text-muted mt-1 d-block">
                                <i class="fas fa-info-circle"></i> @Localize("Demo"): User!321
                            </small>
                        </div>

                        <!-- Remember Me -->
                        <div class="form-check mb-4">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="rememberMe"
                                   name="rememberMe">
                            <label class="form-check-label" for="rememberMe">
                                @Localize("RememberMe")
                            </label>
                        </div>

                        <!-- Login Button -->
                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                            <i class="fas fa-sign-in-alt"></i> @Localize("SignIn")
                        </button>
                    </form>

                    <!-- Divider -->
                    <div class="text-center mb-4">
                        <small class="text-muted">
                            <span style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                                @Localize("Or")
                            </span>
                        </small>
                    </div>

                    <!-- Admin Login Link -->
                    <div class="text-center mb-4">
                        <a href="@Url.Action("AdminLogin", "Account")" class="btn btn-secondary btn-lg w-100">
                            <i class="fas fa-shield-alt"></i> @Localize("AdminLogin")
                        </a>
                    </div>

                    <!-- Footer Links -->
                    <div class="text-center">
                        <p class="text-muted mb-3">
                            @Localize("NoAccount")
                            <a href="#" style="color: var(--primary-color); text-decoration: none;">
                                @Localize("RegisterHere")
                            </a>
                        </p>
                        <small class="text-muted">
                            <a href="@Url.Action("Index", "Home")" class="text-muted text-decoration-none">
                                <i class="fas fa-arrow-left"></i> @Localize("BackToHome")
                            </a>
                        </small>
                    </div>
                </div>
            </div>

            <!-- Help Section -->
            <div class="mt-4">
                <div class="card" style="background: var(--bg-card); border: 1px solid var(--border-color);">
                    <div class="card-body">
                        <h6 class="card-title mb-3">
                            <i class="fas fa-question-circle" style="color: var(--accent-color);"></i> @Localize("NeedHelp")
                        </h6>
                        <ul class="list-unstyled small">
                            <li class="mb-2">
                                <a href="@Url.Action("Index", "FAQ")" class="text-decoration-none text-muted">
                                    <i class="fas fa-book"></i> @Localize("FAQ")
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("Index", "Support")" class="text-decoration-none text-muted">
                                    <i class="fas fa-headset"></i> @Localize("ContactUs")
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Security Info -->
    <div class="row mt-5">
        <div class="col-lg-6 mx-auto">
            <div class="alert alert-info" role="alert">
                <i class="fas fa-lock"></i> <strong>@Localize("AccountSecured")!</strong>
                <p class="mb-0 mt-2 small">
                    @Localize("PasswordProtection")
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control, .form-control-lg {
        background: var(--bg-dark);
        border: 2px solid var(--border-color);
        color: var(--text-light);
    }

        .form-control:focus, .form-control-lg:focus {
            background: var(--bg-dark);
            border-color: var(--primary-color);
            color: var(--text-light);
            box-shadow: 0 0 0 0.2rem rgba(147, 51, 234, 0.25);
        }

    .form-label {
        color: var(--text-light);
        font-weight: 600;
    }

    .form-check-input {
        background: var(--bg-dark);
        border: 2px solid var(--border-color);
    }

        .form-check-input:checked {
            background: var(--primary-color);
            border-color: var(--primary-color);
        }
</style>
