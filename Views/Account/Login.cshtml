@model SafeCasino.Models.LoginRequest
@{
    ViewData["Title"] = "Login";
}

<div class="user-login-container">
    <div class="login-card">
        <div class="text-center mb-4">
            <i class="fas fa-dice-five fa-3x text-primary"></i>
            <h1 class="mt-3">SafeCasino</h1>
            <p class="text-muted">@Html.Localize("WelcomeBack")</p>
        </div>

        @if (ViewData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <strong>@Html.Localize("Error"):</strong> @ViewData["ErrorMessage"]
            </div>
        }

        <form method="post" action="/Account/Login">
            <div class="mb-3">
                <label class="form-label">@Html.Localize("Email")</label>
                <input type="email" name="Email" class="form-control" placeholder="@Html.Localize("EnterEmail")" required />
            </div>

            <div class="mb-3">
                <label class="form-label">@Html.Localize("Password")</label>
                <input type="password" name="Password" class="form-control" placeholder="@Html.Localize("EnterPassword")" required />
            </div>

            <div class="mb-3">
                <input type="checkbox" name="RememberMe" class="form-check-input" id="remember" />
                <label class="form-check-label" for="remember">@Html.Localize("RememberMe")</label>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3">
                <i class="fas fa-sign-in-alt me-2"></i>@Html.Localize("Login")
            </button>

            <div class="text-center">
                <span>@Html.Localize("DontHaveAccount")?</span>
                <a href="/Account/Register">@Html.Localize("Register")</a>
            </div>
        </form>

        <div class="text-center mt-4">
            <a href="/">@Html.Localize("BackToHome")</a>
        </div>
    </div>

    <div class="language-switcher">
        <a href="/Language/Set/nl" class="btn btn-sm btn-outline-light">NL</a>
        <a href="/Language/Set/en" class="btn btn-sm btn-outline-light">EN</a>
    </div>
</div>

<style>
    .user-login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
    }

    .login-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        width: 100%;
        max-width: 480px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    .language-switcher {
        position: fixed;
        top: 20px;
        right: 20px;
    }
</style>
