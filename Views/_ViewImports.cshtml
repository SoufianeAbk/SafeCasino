@using SafeCasino
@using SafeCasino.Models
@using SafeCasino.Services
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@inject ILocalizationService localizationService

@{
    var currentLanguage = ViewContext.HttpContext.Request.Cookies["language"] ?? "nl";
}

@functions {
    private string Localize(string key)
    {
        var lang = ViewContext.HttpContext.Request.Cookies["language"] ?? "nl";
        return localizationService.GetString(key, lang) ?? key;
    }
}

