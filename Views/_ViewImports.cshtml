@using SafeCasino
@using SafeCasino.Models
@using SafeCasino.Services
@using SafeCasino.Helpers
@using static SafeCasino.Helpers.LocalizationHelper
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@inject ILocalizationService LocalizationService

@functions {
    public string Localize(string key)
    {
        var language = ViewContext.HttpContext.Request.Cookies["language"] ?? "nl";
        return LocalizationService.GetString(key, language) ?? key;
    }
}
